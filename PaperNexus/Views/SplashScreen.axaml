<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       x:Class="PaperNexus.Views.SplashScreen"
       Width="380" Height="420"
       WindowStartupLocation="CenterScreen"
       SystemDecorations="None"
       CanResize="False"
       Topmost="True"
       Background="#1E1E1E">

    <Grid RowDefinitions="*,Auto,Auto,Auto">

        <Image Grid.Row="0"
               Source="avares://PaperNexus/Assets/logo.png"
               Stretch="Uniform"
               Margin="48,40,48,16" />

        <TextBlock Grid.Row="1"
                   Text="Paper Nexus"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#E0E0E0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="2"
                   x:Name="VersionText"
                   FontSize="12"
                   Foreground="#505050"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="3"
                   Text="Starting up..."
                   FontSize="13"
                   Foreground="#707070"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,36" />

    </Grid>
</Window>
